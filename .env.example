# Gemini AI API key (server-side only, never expose to client)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (injected by Vercel / AI Studio at runtime)
APP_URL="MY_APP_URL"

# URL of the standalone Galaxa Store project (used by the "Browse" nav link).
VITE_STORE_URL="http://localhost:5174"

# Origins allowed to make cross-origin, credentialed requests to this API
# (the standalone Galaxa Store project's dev/prod URLs). Server-side only.
STORE_DEV_ORIGIN="http://localhost:5174"
STORE_PROD_ORIGIN="MY_STORE_PROD_URL"

# Firebase client-side config (these are public identifiers — safe to expose)
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"

# GalaxaSpace admin — Firebase Auth UID of the admin account.
# Must also be pasted into firestore.rules' isSpaceAdmin() function —
# Firestore rules cannot read environment variables.
VITE_ADMIN_UID="MY_FIREBASE_ADMIN_UID"

# GalaxaSpace weekly ritual — server-side only, never exposed to the client.
# Free Vercel Cron Job (Hobby plan supports 1 daily cron at no cost) calls
# POST /api/space/cron/daily-ritual once a day; this secret authenticates
# that request (Vercel sets it automatically as a Bearer token when a cron
# job fires). Set to any random string.
CRON_SECRET="MY_RANDOM_CRON_SECRET"

# Firebase Admin SDK service account — free on the Spark (no-cost) plan.
# Download from Firebase Console -> Project Settings -> Service Accounts ->
# Generate new private key. Used only by the cron endpoint above (bypasses
# Firestore rules to write space_settings/dailyTheme + the daily system post).
FIREBASE_ADMIN_PROJECT_ID="MY_PROJECT_ID"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxxxx@MY_PROJECT_ID.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# Optional — used to build absolute links in the Sunday "Weekly Best Posts"
# summary post. Defaults to https://galaxatech.com if unset.
SITE_ORIGIN="https://galaxatech.com"
