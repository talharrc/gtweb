# Gemini AI API key (server-side only, never expose to client)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (injected by Vercel / AI Studio at runtime)
APP_URL="MY_APP_URL"

# URL of the standalone Galaxa Store project (used by the "Browse" nav link).
VITE_STORE_URL="http://localhost:5174"

# Origins allowed to make cross-origin, credentialed requests to this API
# (the standalone Galaxa Store project's dev/prod URLs). Server-side only.
STORE_DEV_ORIGIN="http://localhost:5174"
STORE_PROD_ORIGIN="MY_STORE_PROD_URL"

# Firebase client-side config (these are public identifiers — safe to expose)
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
