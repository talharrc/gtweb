rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Auth now uses Firebase Custom Tokens with custom claims set by our API.
    // request.auth.token.role is set to 'admin' | 'client' | 'builder'
    // request.auth.token.email matches the user's real email
    // request.auth.token.projectId is the linked project

    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isClient() {
      return request.auth != null && request.auth.token.role == 'client';
    }

    function isBuilder() {
      return request.auth != null && request.auth.token.role == 'builder';
    }

    function authEmail() {
      return request.auth != null ? request.auth.token.email : '';
    }

    function isProjectClient() {
      return request.auth != null &&
             resource.data.clientEmail == authEmail();
    }

    function isProjectBuilder() {
      return request.auth != null &&
             resource.data.builderEmails is list &&
             authEmail() in resource.data.builderEmails;
    }

    function clientOnProject(projectId) {
      return request.auth != null &&
             get(/databases/$(database)/documents/projects/$(projectId)).data.clientEmail == authEmail();
    }

    function builderOnProject(projectId) {
      let p = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return request.auth != null &&
             p.builderEmails is list &&
             authEmail() in p.builderEmails;
    }

    // Users collection — legacy, may be empty now (credentials moved to 'credentials' collection)
    match /users/{uid} {
      allow read, write: if isAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isAdmin() || isProjectClient() || isProjectBuilder();
      allow write: if isAdmin();

      match /updates/{updateId} {
        allow read: if isAdmin() || clientOnProject(projectId) || builderOnProject(projectId);
        allow create: if isAdmin() || builderOnProject(projectId);
        allow update, delete: if isAdmin();
      }
    }

    // Top-level updates (legacy + admin activity feed)
    match /updates/{updateId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Documents
    match /documents/{docId} {
      allow read: if isAdmin() || (request.auth != null &&
        (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientEmail == authEmail() ||
         (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.builderEmails is list &&
          authEmail() in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.builderEmails)));
      allow write: if isAdmin();
    }

    // Forms
    match /forms/{formId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // Payments — admin only
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.recipientUid || isAdmin();
      allow create, delete: if isAdmin();
    }

    // Deliverable reviews
    match /deliverable_reviews/{reviewId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // Public write collections
    match /audit_submissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /contact_submissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /gbp_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Credentials — written only by Firebase Admin SDK (server-side), never by client
    match /credentials/{id} {
      allow read, write: if false;
    }

    // Content
    match /content/{contentId} {
      allow read: if resource.data.isPublic == true || request.auth != null;
      allow write: if isAdmin();
    }

    // Site config — public read, admin write
    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
