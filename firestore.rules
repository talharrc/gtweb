rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'mail.galaxatech@gmail.com';
    }

    // Email-based project membership (works for list queries using resource.data)
    function isProjectClient() {
      return request.auth != null &&
             resource.data.clientEmail == request.auth.token.email;
    }

    function isProjectBuilder() {
      return request.auth != null &&
             resource.data.builderEmails is list &&
             request.auth.token.email in resource.data.builderEmails;
    }

    // For subcollection access — fetch parent project via get()
    function clientOnProject(projectId) {
      return request.auth != null &&
             get(/databases/$(database)/documents/projects/$(projectId)).data.clientEmail == request.auth.token.email;
    }

    function builderOnProject(projectId) {
      let p = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return request.auth != null &&
             p.builderEmails is list &&
             request.auth.token.email in p.builderEmails;
    }

    // Users — self-read/create, admin full control, self can update own doc
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();
    }

    // Projects — email-based read, admin write
    match /projects/{projectId} {
      allow read: if isAdmin() || isProjectClient() || isProjectBuilder();
      allow write: if isAdmin();

      // Updates subcollection — client and builder read; builder writes
      match /updates/{updateId} {
        allow read: if isAdmin() || clientOnProject(projectId) || builderOnProject(projectId);
        allow create: if isAdmin() || builderOnProject(projectId);
        allow update, delete: if isAdmin();
      }
    }

    // Top-level updates (legacy + admin activity feed)
    match /updates/{updateId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Documents
    match /documents/{docId} {
      allow read: if isAdmin() || (request.auth != null &&
        (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientEmail == request.auth.token.email ||
         (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.builderEmails is list &&
          request.auth.token.email in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.builderEmails)));
      allow write: if isAdmin();
    }

    // Forms
    match /forms/{formId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // Payments — admin only
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.recipientUid || isAdmin();
      allow create, delete: if isAdmin();
    }

    // Deliverable reviews
    match /deliverable_reviews/{reviewId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // Public write collections
    match /audit_submissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /contact_submissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /gbp_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Credentials collection (legacy — admin only)
    match /credentials/{id} {
      allow read, write: if isAdmin();
    }

    // Content — public items readable by all, members-only require auth
    match /content/{contentId} {
      allow read: if resource.data.isPublic == true || request.auth != null;
      allow write: if isAdmin();
    }

    // Site config — public read, admin write
    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
