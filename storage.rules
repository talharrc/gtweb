rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /space/{postId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin-managed uploads (portfolio images, project documents). Auth is
    // enforced at the application layer via JWT httpOnly cookies, same
    // model as Firestore's open rules below — not Firebase Auth.
    match /portfolio/{allPaths=**} {
      allow read, write: if true;
    }
    match /projects/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
